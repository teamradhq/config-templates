<?xml version="1.0"?>
<ruleset name="WhiteSpace">
    <description>Lines and Spacing</description>

    <arg name="extensions" value="php"/>
    <arg name="colors"/>

    <file>src</file>
    <file>tests</file>
    <file>rector.php</file>

    <rule ref="PSR12.ControlStructures.ControlStructureSpacing">
        <exclude name="PSR12.ControlStructures.ControlStructureSpacing.SpacingAfterOpenBrace"/>
        <exclude name="PSR12.ControlStructures.ControlStructureSpacing.SpacingBeforeCloseBrace"/>
    </rule>

    <rule ref="PSR12.Classes.AnonClassDeclaration.SpaceAfterKeyword)">
        <exclude name="PSR12.Classes.AnonClassDeclaration.SpaceAfterKeyword.Found"/>
    </rule>

    <rule ref="Generic.Files.LineLength">
        <properties>
            <property name="lineLimit" value="120"/>
            <property name="absoluteLineLimit" value="120"/>
        </properties>
    </rule>
</ruleset>
